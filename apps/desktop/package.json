{
  "name": "@docuforge/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev": "tsc -p tsconfig.electron.json && wait-on tcp:5173 tcp:3847 && cross-env NODE_ENV=development electron .",
    "build:app": "npm run build:electron -w @docuforge/desktop && npm run build -w @docuforge/web && electron-builder"
  },
  "dependencies": {
    "@docuforge/config": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.docuforge.app",
    "productName": "DocuForge",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "dist-electron/**/*",
      "../web/dist/**/*",
      "../api/**/*",
      "../../packages/remotion/**/*",
      "../../projects/**/*"
    ],
    "mac": {
      "category": "public.app-category.video"
    },
    "win": {
      "target": "nsis"
    }
  }
}
