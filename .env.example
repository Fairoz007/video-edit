# Unsplash — https://unsplash.com/oauth/applications
UNSPLASH_APPLICATION_ID=953403
UNSPLASH_ACCESS_KEY=Oe5UIQx8GZV5RXaCY8hKJZRig8Dgv1SKtB5-pFDJ3Kc
UNSPLASH_SECRET_KEY=-6T4N-Ch9m9KwYGHH38rp8YFnKy6Wy3Uvy863r2MaU4

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay — https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Backend
BACKEND_PORT=3847

# Chatterbox-TTS (Resemble AI) — Turbo + Multilingual v3
CHATTERBOX_PYTHON=python3.11
# cuda | mps | cpu | (empty = auto: CUDA → MPS → CPU)
CHATTERBOX_DEVICE=
CHATTERBOX_MTL_T3=v3
CHATTERBOX_WARMUP=0
# Models to prefetch on npm install (turbo | mtl). mtl is large — add only if you need multilingual TTS.
CHATTERBOX_SETUP_MODELS=turbo
# 0 = persistent worker (faster for batch on CUDA). 1 or unset = one-shot per utterance (default, most reliable)
CHATTERBOX_ONESHOT=1
CHATTERBOX_START_TIMEOUT_MS=180000
# On API startup, pre-generate one preview MP3 per voice (all languages) under cache/voice-preview/presets/
CHATTERBOX_WARM_PREVIEWS=1
TTS_VOICE=chatterbox-turbo
TTS_RATE=175
TTS_PITCH=0

# --- Windows + NVIDIA GPU (e.g. RTX 2060, Ryzen 5700X, 16GB+ RAM) ---
# Copy these over the Chatterbox lines above for fast CUDA inference:
#   CHATTERBOX_PYTHON=python
#   CHATTERBOX_DEVICE=cuda
#   CHATTERBOX_MTL_T3=v3
#   CHATTERBOX_WARMUP=0
#   CHATTERBOX_ONESHOT=0
#   CHATTERBOX_START_TIMEOUT_MS=180000
#   TTS_VOICE=chatterbox-turbo
# Install once: npm run chatterbox:install
# Requires CUDA PyTorch — if GPU is not used, reinstall torch with CUDA from https://pytorch.org
#
# --- macOS Apple Silicon (M1/M2/M3) ---
#   CHATTERBOX_DEVICE=mps
#   CHATTERBOX_ONESHOT=1
# If preview is very slow or OOM, try CHATTERBOX_DEVICE=cpu and run only: npm run dev:backend

# Groq — free LLM for script generation (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Video defaults (3:00 documentary with intro/outro)
VIDEO_TARGET_DURATION_SEC=180
NARRATION_WPM=150
MIN_IMAGE_WIDTH=1920
CHANNEL_NAME=DocuForge

# Walkthrough / Stitch-style slides (seconds per screen)
WALKTHROUGH_SEC_PER_SCREEN=4

# Render defaults
DEFAULT_RESOLUTION=1080p
# Optional — defaults to npm-bundled ffmpeg from @ffmpeg-installer/ffmpeg after `npm install`
FFMPEG_PATH=